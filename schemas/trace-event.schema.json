{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentnest.example/schemas/trace-event.schema.json",
  "title": "AgentNest Demo Trace Event",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "trace_id",
    "tenant_id",
    "biz_domain",
    "logical_agent_id",
    "runtime_instance_id",
    "agent_id",
    "session_id",
    "task_id",
    "execution_context_id",
    "event_type",
    "decision",
    "reason",
    "payload",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0",
      "type": "string"
    },
    "event_id": {
      "minLength": 1,
      "maxLength": 128,
      "type": "string"
    },
    "trace_id": {
      "minLength": 1,
      "maxLength": 128,
      "type": "string"
    },
    "tenant_id": {
      "minLength": 1,
      "maxLength": 128,
      "type": "string"
    },
    "biz_domain": {
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Z][A-Z0-9_]*$",
      "type": "string"
    },
    "logical_agent_id": {
      "anyOf": [
        {
          "minLength": 1,
          "maxLength": 128,
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "runtime_instance_id": {
      "anyOf": [
        {
          "minLength": 1,
          "maxLength": 128,
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "agent_id": {
      "anyOf": [
        {
          "minLength": 1,
          "maxLength": 128,
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "session_id": {
      "anyOf": [
        {
          "minLength": 1,
          "maxLength": 128,
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "task_id": {
      "anyOf": [
        {
          "minLength": 1,
          "maxLength": 128,
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "execution_context_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "event_type": {
      "anyOf": [
        {
          "const": "REQUEST_ACCEPTED",
          "type": "string"
        },
        {
          "const": "L1_ENSURE_STARTED",
          "type": "string"
        },
        {
          "const": "L1_PROFILE_CREATED",
          "type": "string"
        },
        {
          "const": "L1_PROFILE_REUSED",
          "type": "string"
        },
        {
          "const": "L1_RESTORED",
          "type": "string"
        },
        {
          "const": "L2_SPAWN_REQUESTED",
          "type": "string"
        },
        {
          "const": "L2_SPAWNED",
          "type": "string"
        },
        {
          "const": "SKILL_SELECTED",
          "type": "string"
        },
        {
          "const": "EXECUTION_CONTEXT_CREATED",
          "type": "string"
        },
        {
          "const": "TOOL_CALL_REQUESTED",
          "type": "string"
        },
        {
          "const": "TOOL_CALL_ALLOWED",
          "type": "string"
        },
        {
          "const": "TOOL_CALL_DENIED",
          "type": "string"
        },
        {
          "const": "TOOL_CALL_COMPLETED",
          "type": "string"
        },
        {
          "const": "MEMORY_READ",
          "type": "string"
        },
        {
          "const": "MEMORY_WRITE",
          "type": "string"
        },
        {
          "const": "CHECKPOINT_STARTED",
          "type": "string"
        },
        {
          "const": "CHECKPOINT_COMPLETED",
          "type": "string"
        },
        {
          "const": "CHECKPOINT_FAILED",
          "type": "string"
        },
        {
          "const": "L2_UNLOADED",
          "type": "string"
        },
        {
          "const": "L1_UNLOAD_STARTED",
          "type": "string"
        },
        {
          "const": "L1_UNLOADED",
          "type": "string"
        },
        {
          "const": "RESTORE_STARTED",
          "type": "string"
        },
        {
          "const": "RESTORE_COMPLETED",
          "type": "string"
        },
        {
          "const": "CAPABILITY_PROFILE_CHANGED",
          "type": "string"
        }
      ]
    },
    "decision": {
      "anyOf": [
        {
          "const": "ALLOW",
          "type": "string"
        },
        {
          "const": "DENY",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "reason": {
      "anyOf": [
        {
          "maxLength": 512,
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "payload": {
      "additionalProperties": false,
      "type": "object",
      "patternProperties": {
        "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$": {}
      }
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    }
  }
}
