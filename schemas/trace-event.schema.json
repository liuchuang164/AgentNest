{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentnest.example/schemas/trace-event.schema.json",
  "title": "AgentNest Demo Trace Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "trace_id",
    "tenant_id",
    "biz_domain",
    "logical_agent_id",
    "runtime_instance_id",
    "agent_id",
    "session_id",
    "task_id",
    "event_type",
    "payload",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "event_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "trace_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "biz_domain": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "logical_agent_id": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 128
    },
    "runtime_instance_id": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 128
    },
    "agent_id": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 128
    },
    "session_id": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 128
    },
    "task_id": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 128
    },
    "execution_context_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "REQUEST_ACCEPTED",
        "L1_ENSURE_STARTED",
        "L1_PROFILE_CREATED",
        "L1_PROFILE_REUSED",
        "L1_RESTORED",
        "L2_SPAWN_REQUESTED",
        "L2_SPAWNED",
        "SKILL_SELECTED",
        "EXECUTION_CONTEXT_CREATED",
        "TOOL_CALL_REQUESTED",
        "TOOL_CALL_ALLOWED",
        "TOOL_CALL_DENIED",
        "TOOL_CALL_COMPLETED",
        "MEMORY_READ",
        "MEMORY_WRITE",
        "CHECKPOINT_STARTED",
        "CHECKPOINT_COMPLETED",
        "CHECKPOINT_FAILED",
        "L2_UNLOADED",
        "L1_UNLOAD_STARTED",
        "L1_UNLOADED",
        "RESTORE_STARTED",
        "RESTORE_COMPLETED",
        "CAPABILITY_PROFILE_CHANGED"
      ]
    },
    "decision": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "ALLOW",
        "DENY",
        null
      ]
    },
    "reason": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 512
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$": {}
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
