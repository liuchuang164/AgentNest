{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentnest.example/schemas/task-request.schema.json",
  "title": "AgentNest Demo Task Request",
  "anyOf": [
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "request_id",
        "tenant_id",
        "input",
        "biz_domain",
        "task_type",
        "resource"
      ],
      "properties": {
        "request_id": {
          "minLength": 1,
          "maxLength": 128,
          "type": "string"
        },
        "idempotency_key": {
          "minLength": 1,
          "maxLength": 256,
          "type": "string"
        },
        "tenant_id": {
          "minLength": 1,
          "maxLength": 128,
          "type": "string"
        },
        "user_id": {
          "minLength": 1,
          "maxLength": 128,
          "type": "string"
        },
        "input": {
          "additionalProperties": false,
          "maxProperties": 50,
          "type": "object",
          "patternProperties": {
            "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$": {}
          }
        },
        "biz_domain": {
          "const": "LEGAL",
          "type": "string"
        },
        "task_type": {
          "const": "LEGAL_EVIDENCE_CHECK",
          "type": "string"
        },
        "resource": {
          "additionalProperties": false,
          "type": "object",
          "required": [
            "resource_type",
            "resource_id"
          ],
          "properties": {
            "resource_type": {
              "const": "CASE",
              "type": "string"
            },
            "resource_id": {
              "minLength": 1,
              "maxLength": 128,
              "type": "string"
            }
          }
        }
      }
    },
    {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "request_id",
        "tenant_id",
        "input",
        "biz_domain",
        "task_type",
        "resource"
      ],
      "properties": {
        "request_id": {
          "minLength": 1,
          "maxLength": 128,
          "type": "string"
        },
        "idempotency_key": {
          "minLength": 1,
          "maxLength": 256,
          "type": "string"
        },
        "tenant_id": {
          "minLength": 1,
          "maxLength": 128,
          "type": "string"
        },
        "user_id": {
          "minLength": 1,
          "maxLength": 128,
          "type": "string"
        },
        "input": {
          "additionalProperties": false,
          "maxProperties": 50,
          "type": "object",
          "patternProperties": {
            "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$": {}
          }
        },
        "biz_domain": {
          "const": "ROBOT_DOG",
          "type": "string"
        },
        "task_type": {
          "const": "ROBOT_DOG_HEALTH_CHECK",
          "type": "string"
        },
        "resource": {
          "additionalProperties": false,
          "type": "object",
          "required": [
            "resource_type",
            "resource_id"
          ],
          "properties": {
            "resource_type": {
              "const": "DEVICE",
              "type": "string"
            },
            "resource_id": {
              "minLength": 1,
              "maxLength": 128,
              "type": "string"
            }
          }
        }
      }
    }
  ]
}
