{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentnest.example/schemas/execution-context.schema.json",
  "title": "AgentNest Demo Execution Context",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "execution_context_id",
    "tenant_id",
    "biz_domain",
    "logical_agent_id",
    "runtime_instance_id",
    "session_id",
    "task_id",
    "allowed_skills",
    "allowed_tools",
    "resource_scope",
    "expires_at"
  ],
  "properties": {
    "execution_context_id": {
      "format": "uuid",
      "type": "string"
    },
    "tenant_id": {
      "minLength": 1,
      "maxLength": 128,
      "type": "string"
    },
    "biz_domain": {
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Z][A-Z0-9_]*$",
      "type": "string"
    },
    "logical_agent_id": {
      "pattern": "^tb_[a-f0-9]{20}$",
      "type": "string"
    },
    "runtime_instance_id": {
      "minLength": 1,
      "maxLength": 128,
      "type": "string"
    },
    "session_id": {
      "minLength": 1,
      "maxLength": 128,
      "type": "string"
    },
    "task_id": {
      "minLength": 1,
      "maxLength": 128,
      "type": "string"
    },
    "allowed_skills": {
      "uniqueItems": true,
      "type": "array",
      "items": {
        "minLength": 1,
        "maxLength": 128,
        "type": "string"
      }
    },
    "allowed_tools": {
      "additionalProperties": false,
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)+$": {
          "minItems": 1,
          "uniqueItems": true,
          "type": "array",
          "items": {
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[a-z][a-z0-9._-]*$",
            "type": "string"
          }
        }
      }
    },
    "resource_scope": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "resource_type",
        "resource_ids"
      ],
      "properties": {
        "resource_type": {
          "minLength": 1,
          "maxLength": 64,
          "type": "string"
        },
        "resource_ids": {
          "minItems": 1,
          "uniqueItems": true,
          "type": "array",
          "items": {
            "minLength": 1,
            "maxLength": 128,
            "type": "string"
          }
        }
      }
    },
    "expires_at": {
      "format": "date-time",
      "type": "string"
    }
  }
}
