{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentnest.example/schemas/capability-token-claims.schema.json",
  "title": "AgentNest Capability Token Claims",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "iss",
    "aud",
    "jti",
    "snapshot_id",
    "tenant_id",
    "biz_domain",
    "logical_agent_id",
    "runtime_instance_id",
    "agent_id",
    "session_id",
    "task_id",
    "tools",
    "memory_scope",
    "data_scope",
    "iat",
    "exp",
    "nonce"
  ],
  "properties": {
    "iss": { "type": "string", "const": "agentnest-control-plane" },
    "aud": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["data-gateway", "external-gateway"] }
    },
    "jti": { "type": "string", "minLength": 1 },
    "parent_jti": { "type": ["string", "null"] },
    "snapshot_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "biz_domain": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
    "logical_agent_id": { "type": "string", "pattern": "^tb_[a-f0-9]{20}$" },
    "runtime_instance_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "tools": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": { "type": "string", "minLength": 1 }
      }
    },
    "memory_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resource_type", "resource_ids"],
      "properties": {
        "resource_type": { "type": ["string", "null"] },
        "resource_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "data_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resource_type", "resource_ids"],
      "properties": {
        "resource_type": { "type": ["string", "null"] },
        "resource_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "iat": { "type": "integer", "minimum": 0 },
    "nbf": { "type": "integer", "minimum": 0 },
    "exp": { "type": "integer", "minimum": 1 },
    "nonce": { "type": "string", "minLength": 16 }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "parent_jti": { "type": "string" }
        },
        "required": ["parent_jti"]
      },
      "then": {
        "properties": {
          "parent_jti": { "minLength": 1 }
        }
      }
    }
  ]
}
