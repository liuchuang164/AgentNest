{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentnest.example/schemas/capability-profile.schema.json",
  "title": "AgentNest Demo Tenant Capability Profile",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "profile_id",
    "version",
    "tenant_id",
    "biz_domain",
    "skills",
    "tools",
    "memory_scopes",
    "lifecycle",
    "created_at"
  ],
  "properties": {
    "profile_id": {
      "minLength": 1,
      "maxLength": 128,
      "type": "string"
    },
    "version": {
      "minimum": 1,
      "type": "integer"
    },
    "tenant_id": {
      "minLength": 1,
      "maxLength": 128,
      "type": "string"
    },
    "biz_domain": {
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Z][A-Z0-9_]*$",
      "type": "string"
    },
    "skills": {
      "uniqueItems": true,
      "type": "array",
      "items": {
        "minLength": 1,
        "maxLength": 128,
        "type": "string"
      }
    },
    "tools": {
      "additionalProperties": false,
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)+$": {
          "minItems": 1,
          "uniqueItems": true,
          "type": "array",
          "items": {
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[a-z][a-z0-9._-]*$",
            "type": "string"
          }
        }
      }
    },
    "memory_scopes": {
      "uniqueItems": true,
      "type": "array",
      "items": {
        "minLength": 1,
        "maxLength": 128,
        "type": "string"
      }
    },
    "lifecycle": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "l1_idle_ttl_seconds",
        "l2_idle_ttl_seconds",
        "max_active_l2"
      ],
      "properties": {
        "l1_idle_ttl_seconds": {
          "minimum": 60,
          "type": "integer"
        },
        "l2_idle_ttl_seconds": {
          "minimum": 1,
          "type": "integer"
        },
        "max_active_l2": {
          "minimum": 1,
          "maximum": 20,
          "type": "integer"
        }
      }
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    }
  }
}
