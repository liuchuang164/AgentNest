{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentnest.example/schemas/capability-profile.schema.json",
  "title": "AgentNest Demo Tenant Capability Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_id",
    "version",
    "tenant_id",
    "biz_domain",
    "skills",
    "tools",
    "memory_scopes",
    "lifecycle",
    "created_at"
  ],
  "properties": {
    "profile_id": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "tenant_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "biz_domain": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "skills": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "tools": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": { "type": "string", "minLength": 1 }
      }
    },
    "memory_scopes": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "l1_idle_ttl_seconds",
        "l2_idle_ttl_seconds",
        "max_active_l2"
      ],
      "properties": {
        "l1_idle_ttl_seconds": { "type": "integer", "minimum": 60 },
        "l2_idle_ttl_seconds": { "type": "integer", "minimum": 1 },
        "max_active_l2": { "type": "integer", "minimum": 1, "maximum": 20 }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
