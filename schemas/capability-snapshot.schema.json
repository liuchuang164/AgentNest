{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentnest.example/schemas/capability-snapshot.schema.json",
  "title": "AgentNest Capability Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "snapshot_id",
    "schema_version",
    "policy_version",
    "tenant_id",
    "biz_domain",
    "skills",
    "tools",
    "memory_scopes",
    "data_scopes",
    "sandbox_policy",
    "lifecycle_policy",
    "created_at",
    "hash"
  ],
  "properties": {
    "snapshot_id": { "type": "string", "minLength": 1 },
    "schema_version": { "type": "string", "const": "1.0" },
    "policy_version": { "type": "integer", "minimum": 1 },
    "tenant_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "biz_domain": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[A-Z][A-Z0-9_]*$" },
    "skills": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "version", "content_hash"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "content_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
        }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "actions", "constraints"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "actions": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "constraints": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "resource_types": {
                "type": "array",
                "uniqueItems": true,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "memory_scopes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "resource_type", "access"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "resource_type": { "type": ["string", "null"] },
          "access": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "enum": ["read", "write"] }
          }
        }
      }
    },
    "data_scopes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["resource_type", "operations"],
        "properties": {
          "resource_type": { "type": "string", "minLength": 1 },
          "operations": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "sandbox_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "scope", "exec_allowed"],
      "properties": {
        "mode": { "enum": ["all"] },
        "scope": { "enum": ["agent"] },
        "exec_allowed": { "type": "boolean" }
      }
    },
    "lifecycle_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["l1_idle_ttl_seconds", "l2_idle_ttl_seconds", "max_active_l2"],
      "properties": {
        "l1_idle_ttl_seconds": { "type": "integer", "minimum": 60 },
        "l2_idle_ttl_seconds": { "type": "integer", "minimum": 1 },
        "max_active_l2": { "type": "integer", "minimum": 1, "maximum": 20 }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  }
}
