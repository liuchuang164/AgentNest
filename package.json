{
  "name": "agentnest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "contracts:generate": "tsx scripts/contracts/generate.ts",
    "contracts:check": "tsx scripts/contracts/generate.ts --check",
    "format": "prettier --write \"{apps,packages,scripts,tests}/**/*.ts\" \"*.{json,mjs,ts,yaml}\" \".github/workflows/*.yml\"",
    "format:check": "prettier --check \"{apps,packages,scripts,tests}/**/*.ts\" \"*.{json,mjs,ts,yaml}\" \".github/workflows/*.yml\"",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm test:unit && pnpm test:contract",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:contract": "pnpm contracts:check && vitest run --config vitest.contract.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "secret:scan": "tsx scripts/verify/secret-scan.ts"
  },
  "devDependencies": {
    "@agentnest/contracts": "workspace:*",
    "@apidevtools/swagger-parser": "12.1.0",
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.3",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "eslint": "10.6.0",
    "openapi-types": "12.1.3",
    "prettier": "3.9.5",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
