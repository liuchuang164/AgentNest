    "@agentnest/control-plane": {
      "path": "apps/control-plane",
      "allowedInternalDependencies": [
        "@agentnest/capability",
        "@agentnest/contracts",
        "@agentnest/openclaw-adapter",
        "@agentnest/persistence"
